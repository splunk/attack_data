# Copy this file to .env and fill in your values.
# migrate.py loads .env automatically (from the scripts/ directory or repo root).

# --- Splunk (shared) ---
SPLUNK_HOST=192.168.1.100

# --- Splunk HEC (upload stage) ---
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
SPLUNK_HEC_PORT=8088

# --- Splunk management API (detect / export stages) ---
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
SPLUNK_PORT=8089

# --- DynamoDB ---
DYNAMODB_TABLE=attack_data_map
AWS_REGION=us-east-1

# --- AWS credentials (optional; boto3 also reads ~/.aws or IAM roles) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
